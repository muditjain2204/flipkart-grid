{
  "name": "smartflow-backend",
  "version": "1.0.0",
  "description": "SmartFlow AI - Multi-Agent Traffic Intelligence System Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.ts --passWithNoTests",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:seed": "ts-node -r tsconfig-paths/register prisma/seed.ts",
    "db:seed:incidents": "ts-node -r tsconfig-paths/register prisma/seed-incidents.ts",
    "db:studio": "prisma studio",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.9.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.4.1",
    "openai": "^4.77.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.17.0",
    "jest": "^30.4.2",
    "prettier": "^3.4.2",
    "prisma": "^6.9.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
